# e:/quran-be/.env

OPENAI_API_KEY=your_groq_api_key_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama-3.3-70b-versatile  # or llama-3.1-8b-instant

PORT=8080

# Comma-separated origins, or * for any (dev only)
CORS_ORIGIN=*

# Max characters of combined user/assistant history sent to the model (guardrail)
MAX_CHAT_CONTEXT_CHARS=12000

# --- Auth ---
JWT_SECRET=change-me-to-a-strong-random-secret
JWT_EXPIRES_IN=7d
